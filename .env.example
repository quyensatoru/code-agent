OPENROUTER_API_KEY=sk-or-v1-your-key
# Optional key pool from multiple accounts. Each request round-robins to the
# next key, and rate-limit/auth/5xx errors fail over to the next key.
# Comma- or newline-separated. OPENROUTER_API_KEY is also added to the pool.
# OPENROUTER_API_KEYS=sk-or-v1-key1,sk-or-v1-key2,sk-or-v1-key3
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost
OPENROUTER_TITLE=OpenRouter Code Agent
OPENROUTER_TIMEOUT_MS=600000

# Two-stage perception: an omni model turns attached media (image/doc/audio/video)
# into text, fed to the text-only planner (OPENROUTER_MODEL). Planner example:
# OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
# OPENROUTER_VISION_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free

# Optional PDF parsing engine for attached docs: native | cloudflare-ai | mistral-ocr
# OPENROUTER_PDF_ENGINE=cloudflare-ai

# Optional reasoning controls. Works only on models/providers that support reasoning tokens.
# OPENROUTER_REASONING_EFFORT=medium
# OPENROUTER_REASONING_MAX_TOKENS=4096
# OPENROUTER_INCLUDE_REASONING=false
# OPENROUTER_VERBOSITY=medium

# Optional OpenRouter server web tools. Enabled by default.
# Set these to false to disable them.
# OPENROUTER_WEB_SEARCH=true
# OPENROUTER_WEB_FETCH=true
# OPENROUTER_WEB_SEARCH_ENGINE=auto
# OPENROUTER_WEB_SEARCH_MAX_RESULTS=5
# OPENROUTER_WEB_FETCH_ENGINE=openrouter
# OPENROUTER_WEB_FETCH_MAX_CONTENT_TOKENS=50000

# Optional local web_search provider. If omitted, local search uses DuckDuckGo HTML best-effort.
# TAVILY_API_KEY=tvly-your-key
# TAVILY_SEARCH_DEPTH=basic

# Context management: estimated token budget before auto-compaction kicks in
# (~80% of this triggers a model-written summary of older turns). Lower it for
# small-context free models.
# OPENROUTER_MAX_CONTEXT_TOKENS=100000

# Stopping pressure for investigation: after this many consecutive search/read
# calls without an edit/run/hypothesis, the loop nudges the agent to converge.
# Set 0 to disable. Default 16.
# OPENROUTER_MAX_SEARCH_STEPS=16

# Read-only datastore inspection (SqlQuery / RedisCommand / MongoQuery). Drivers
# are lazy-imported — install only what you use: npm i pg | mysql2 | better-sqlite3 | redis | mongodb
# DATABASE_URL=postgres://user:pass@localhost:5432/db   # or mysql://… or sqlite:./data.db
# REDIS_URL=redis://localhost:6379
# MONGODB_URL=mongodb://localhost:27017
# MONGODB_DB=app
# RabbitMQ & other HTTP-managed services: no env needed — use the HttpProbe tool
# against the management API, e.g. http://guest:guest@localhost:15672/api/queues
